SESSION_SECRET=change_me_to_a_random_secret

# Primary AI provider
GEMINI_API_KEY=

# Optional AI provider fallbacks (used automatically if configured)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=

# Supabase (server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SECRET_KEY=

# Optional database
DATABASE_URL=

# Locus API Configuration (Required for deployments)
LOCUS_API_KEY=your_locus_api_key_here
LOCUS_API_URL=https://api.locus.dev

# GitHub Integration (Optional - for CI/CD)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_for_security
GITHUB_DEPLOY_BRANCHES=main,master
